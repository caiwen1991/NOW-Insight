# Copy this file to .env.local and fill in your key.
# .env.local is gitignored — never commit real keys.

# Finnhub delayed-quote API key. Free key: https://finnhub.io
# Used ONLY server-side in src/app/api/quote/route.ts (never exposed to the browser).
FINNHUB_API_KEY=

# Twelve Data API key for the hero trend chart's price history. Free key: https://twelvedata.com
# Used ONLY server-side in src/app/api/series/route.ts (never exposed to the browser).
# Without it, the chart falls back to the ambient animation.
TWELVE_DATA_API_KEY=
